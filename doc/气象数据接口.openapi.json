        "summary": "气象数据",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [
          {
            "name": "beginTime",
            "in": "query",
            "description": "开始时间",
            "required": true,
            "example": "2025-1-1",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "endTime",
            "in": "query",
