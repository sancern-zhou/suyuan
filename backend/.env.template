# ============================================
# 数据库配置 (Database Configuration)
# ============================================

# PostgreSQL + TimescaleDB 连接字符串
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# 示例: postgresql+asyncpg://postgres:password@localhost:5432/weather_db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/weather_db

# ============================================
# 外部API配置 (External APIs)
# ============================================

# 站点和行政区查询API
STATION_API_BASE_URL=http://180.184.91.74:9095

# 监测数据查询API
MONITORING_DATA_API_URL=http://180.184.91.74:9091
VOCS_DATA_API_URL=http://180.184.91.74:9092
PARTICULATE_DATA_API_URL=http://180.184.91.74:9093

# 气象数据API
METEOROLOGICAL_API_URL=http://180.184.30.94/api/AiDataService/.../Query
METEOROLOGICAL_API_KEY=1882bb80-16a0-419a-ae3e-f442471909d3

# 上风向分析API
UPWIND_ANALYSIS_API_URL=http://192.168.20.2:9092

# 高德地图API密钥（可选）
AMAP_PUBLIC_KEY=your-amap-key-here

# ============================================
# LLM配置 (LLM Configuration)
# ============================================

# LLM提供商: openai, deepseek, anthropic
LLM_PROVIDER=deepseek

# DeepSeek配置
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-reasoner

# OpenAI配置（可选）
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic配置（可选）
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================
# 服务器配置 (Server Configuration)
# ============================================

# 主机和端口
HOST=0.0.0.0
PORT=8000

# CORS跨域配置（前端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================
# Redis配置 (可选，用于缓存)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# 分析参数配置 (Analysis Parameters)
# ============================================

# 上风向企业搜索半径（公里）
DEFAULT_SEARCH_RANGE_KM=5.0

# 返回的最大企业数量
DEFAULT_MAX_ENTERPRISES=30

# 展示的企业数量
DEFAULT_TOP_N_ENTERPRISES=8

# API请求超时时间（秒）
REQUEST_TIMEOUT_SECONDS=60

# ============================================
# 日志配置 (Logging Configuration)
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG=False

# ============================================
# 数据获取配置 (Data Fetching Configuration)
# ============================================

# 是否启用数据自动获取
ENABLE_AUTO_FETCHING=True

# ERA5数据获取时间（Cron表达式，默认每天凌晨2点）
ERA5_FETCH_SCHEDULE=0 2 * * *

# 观测数据获取时间（Cron表达式，默认每小时）
OBSERVED_FETCH_SCHEDULE=0 * * * *
