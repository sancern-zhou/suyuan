# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# External API Endpoints
STATION_API_BASE_URL=http://180.184.91.74:9095
MONITORING_DATA_API_URL=http://180.184.91.74:9091
VOCS_DATA_API_URL=http://180.184.91.74:9092
PARTICULATE_DATA_API_URL=http://180.184.91.74:9093
METEOROLOGICAL_API_URL=http://180.184.30.94/api/AiDataService/ReportApplication/UserReportDataQuery/Query
UPWIND_ANALYSIS_API_URL=http://192.168.20.2:9092

# API Keys
METEOROLOGICAL_API_KEY=1882bb80-16a0-419a-ae3e-f442471909d3
AMAP_PUBLIC_KEY=your_amap_key_here

# LLM Configuration (choose your provider)
LLM_PROVIDER=openai  # options: openai, anthropic, deepseek, mimo
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# DeepSeek Configuration (if using)
DEEPSEEK_API_KEY=sk-6b609b70b55d4562ab73f8f805f899d4
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Configuration (if using)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Xiaomi Mimo Configuration (if using)
MIMO_API_KEY=your_mimo_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2-flash  # options: mimo-v2-flash, mimo-v2.5, mimo-v2.5-pro, mimo-v2-pro, mimo-v2-omni

# Redis (for caching and async tasks)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL (seconds)
CACHE_TTL_CONFIG=3600
CACHE_TTL_ANALYSIS=1800
CACHE_TTL_WEATHER=600

# Analysis Parameters
DEFAULT_SEARCH_RANGE_KM=5
DEFAULT_MAX_ENTERPRISES=30
DEFAULT_TOP_N_ENTERPRISES=8
WIND_SPEED_LOW_THRESHOLD=1.5
CANDIDATE_RADIUS_KM=25
NEARBY_STATIONS_RADIUS_KM=20
NEARBY_STATIONS_MAX_RESULTS=5
SECTOR_HALF_ANGLE=11.25

# Retry Configuration
MAX_RETRIES=3
RETRY_INTERVAL_MS=100
REQUEST_TIMEOUT_SECONDS=30

# ==================== Weather Data Storage Configuration ====================
# PostgreSQL + TimescaleDB Database
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/weather_db
DATABASE_URL=postgresql://username:password@localhost:5432/weather_db

# ERA5 Reanalysis Data Download
ERA5_DOWNLOAD_ENABLED=true
ERA5_DOWNLOAD_HOUR=2        # Daily download time (2 AM local time)

# Observed Weather Data Download
ENABLE_OBSERVED_DOWNLOAD=true
OBSERVED_DOWNLOAD_HOUR=3    # Daily download time (3 AM local time)

# ==================== Observed Weather Tools Configuration ====================
# WeatherAPI.com API Key (Optional)
# Free tier: 1,000,000 requests/month
# Register at: https://www.weatherapi.com/signup.aspx
# If not configured, system will use Open-Meteo only (10,000 requests/day, no API key required)
WEATHERAPI_KEY=your_weatherapi_key_here
